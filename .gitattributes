# Trim CI/internal noise from `git archive` (and GitHub's auto Source code
# archives, which git archive generates) per the org release-artifact standard
# Per the org release-artifact standard. Directory excludes use the `/**` form:
# bare `dir/` patterns do not recurse reliably for export-ignore.
.gitattributes export-ignore
.gitignore export-ignore
.github/** export-ignore
tests/** export-ignore
